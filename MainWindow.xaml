<Window x:Class="InternetRepair.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="学生目录 · 网络接入工具" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F5F7FA"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" Opacity="0.15" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 按钮样式（深蓝色主题） -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2C6B9E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F4E73"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F3A55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 超链接样式 -->
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#2C6B9E"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- RadioButton 样式 -->
        <Style TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <!-- TextBlock 样式 -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <!-- Label 样式（用于公告时间） -->
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#5D6D7E"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="0.8*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 左侧：连接控制区 ========== -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,20,0">
            <StackPanel Margin="24">
                <!-- 标题 -->
                <TextBlock Text="🔌 选择连接方式" FontSize="20" FontWeight="SemiBold" 
                           Foreground="#2C6B9E" Margin="0,0,0,10"/>

                <!-- 当前网络状态（置于顶部） -->
                <Border Background="#F8F9FC" CornerRadius="8" Margin="0,0,0,10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="📡 当前网络状态" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock x:Name="网络状态文本" Text="检测中..." FontSize="12" Foreground="#5D6D7E" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 连接选项 -->
                <RadioButton x:Name="Proxy1Radio" Content="通过代理1接入" GroupName="ConnectionType" Margin="0,8"/>
                <RadioButton x:Name="Proxy2Radio" Content="通过代理2连入" GroupName="ConnectionType" Margin="0,8"/>
                <RadioButton x:Name="VpnRadio" Content="通过VPN接入" GroupName="ConnectionType" Margin="0,8"/>

                <!-- 进度条区域 -->
                <StackPanel Margin="0,30,0,0">
                    <TextBlock x:Name="进度显示" Text="连接状态：就绪" FontSize="13" Foreground="#5D6D7E" Margin="0,0,0,8"/>
                    <ProgressBar x:Name="连接进度条" Height="8" Background="#E9ECF0" Foreground="#2C6B9E" 
                                 BorderThickness="0" Margin="0,5,0,20"/>
                </StackPanel>

                <!-- 连接按钮 -->
                <Button x:Name="连接按钮" Content="开始连接" Click="Button_Click" Height="48" Margin="0,10,0,0"/>

                <!-- 帮助面板（保留帮助链接，可简化） -->
                <Border Background="#F8F9FC" CornerRadius="8" Margin="0,25,0,0" Padding="12">
                    <StackPanel>
                        <TextBlock FontSize="12">
                            需要帮助？
                            <Hyperlink NavigateUri="http://10.88.202.73/tutorial/show.html?file=Networkrepair" RequestNavigate="Hyperlink_RequestNavigate">访问帮助中心</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 说明文字 -->
                <TextBlock Text="选择一种方式后点击连接，进度条将显示状态。" 
                           FontSize="12" Foreground="#95A5A6" TextWrapping="Wrap" 
                           Margin="0,20,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ========== 右侧：关于与公告区 ========== -->
        <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="20,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24">
                    <!-- 标题 -->
                    <TextBlock Text="ℹ️ 关于与更多" FontSize="20" FontWeight="SemiBold" 
                               Foreground="#2C6B9E" Margin="0,0,0,20"/>

                    <!-- 超链接区域 -->
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14">
                        查看关于此工具的<Hyperlink NavigateUri="http://10.88.202.73/tutorial/show.html?file=Networkrepair" RequestNavigate="Hyperlink_RequestNavigate">更多信息</Hyperlink>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14">
                        访问我们的<Hyperlink NavigateUri="http://10.88.202.73" RequestNavigate="Hyperlink_RequestNavigate">网站</Hyperlink>以使用我们提供的其它服务
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,20" FontSize="14">
                        查看我们的<Hyperlink NavigateUri="https://psstunet.github.io/" RequestNavigate="Hyperlink_RequestNavigate">月度报告</Hyperlink>
                    </TextBlock>

                    <!-- 分隔线 -->
                    <Rectangle Height="1" Fill="#E9ECF0" Margin="0,0,0,20"/>

                    <!-- 公告区域 -->
                    <TextBlock Text="📢 最新公告" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock x:Name="公告内容" TextWrapping="Wrap" FontSize="13" 
                               Foreground="#5D6D7E" Text="正在加载公告..." Margin="0,0,0,10"/>
                    <Label x:Name="公告时间" Content="公告时间" Margin="0,0,0,10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>